{
  "name": "ztm-chat",
  "version": "2026.2.15",
  "description": "ZTM Chat channel plugin for OpenClaw",
  "type": "module",
  "overrides": {
    "tar": ">=7.5.7"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "openclaw": "^2026.2.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
