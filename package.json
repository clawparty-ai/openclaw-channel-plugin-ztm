{
  "name": "@flomesh/ztm-chat",
  "version": "2026.2.18-beta.1",
  "description": "ZTM Chat channel plugin for OpenClaw",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "overrides": {
    "tar": ">=7.5.7"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:unreleased": "git-cliff --unreleased",
    "changelog:preview": "git-cliff --unreleased"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "openclaw": "^2026.2.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "conventional-changelog-angular": "^8.1.0",
    "conventional-changelog-cli": "^2.2.2",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "ztm-chat",
      "label": "ZTM Chat",
      "selectionLabel": "ZTM Chat",
      "blurb": "Decentralized P2P messaging via ZTM network",
      "aliases": [
        "ztm"
      ],
      "order": 40,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@flomesh/ztm-chat",
      "localPath": "extensions/ztm-chat",
      "defaultChoice": "npm"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
